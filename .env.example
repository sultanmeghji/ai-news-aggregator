# AI News Aggregator - Environment Configuration
# Copy this file to .env and fill in your actual API keys

# ===========================================
# REQUIRED API KEYS
# ===========================================

# News API - Get your free API key from https://newsapi.org/
# Free tier: 1000 requests/month, 250 requests/day
NEWS_API_KEY=your_news_api_key_here

# Anthropic Claude API - Get from https://console.anthropic.com/
# Required for AI-generated summaries and content
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================================
# OPTIONAL API KEYS
# ===========================================

# Social Pilot API - Get from https://app.socialpilot.co/api
# Required only if you want to auto-post to social media
SOCIAL_PILOT_API_KEY=your_social_pilot_api_key_here

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Server port (default: 5000)
PORT=5000

# Environment mode (development/production)
NODE_ENV=development

# ===========================================
# API CONFIGURATION
# ===========================================

# News API base URL (don't change unless using a proxy)
NEWS_API_BASE_URL=https://newsapi.org/v2

# Anthropic API base URL (don't change unless using a proxy)
ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# Social Pilot API base URL (don't change unless using a proxy)
SOCIAL_PILOT_API_BASE_URL=https://api.socialpilot.co

# ===========================================
# RATE LIMITING CONFIGURATION
# ===========================================

# News API rate limits (requests per minute)
NEWS_API_RATE_LIMIT=5

# Anthropic API rate limits (requests per minute)
ANTHROPIC_API_RATE_LIMIT=50

# Social Pilot API rate limits (requests per minute)
SOCIAL_PILOT_API_RATE_LIMIT=10

# ===========================================
# DATA STORAGE CONFIGURATION
# ===========================================

# Data directory for CSV files
DATA_DIR=./data

# Enable/disable data persistence (true/false)
ENABLE_DATA_PERSISTENCE=true

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

# Log level (error/warn/info/debug)
LOG_LEVEL=info

# Enable/disable API request logging
LOG_API_REQUESTS=true

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Enable/disable HTTPS in production
ENABLE_HTTPS=false

# ===========================================
# FEATURE FLAGS
# ===========================================

# Enable/disable duplicate story detection
ENABLE_DUPLICATE_DETECTION=true

# Enable/disable AI content generation
ENABLE_AI_SUMMARIES=true

# Enable/disable social media posting
ENABLE_SOCIAL_POSTING=true

# ===========================================
# ADVANCED CONFIGURATION
# ===========================================

# Maximum number of stories to fetch per request
MAX_STORIES_PER_REQUEST=50

# Story cache duration in minutes
STORY_CACHE_DURATION=60

# API timeout in milliseconds
API_TIMEOUT=30000

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================

# Enable/disable hot reloading in development
ENABLE_HOT_RELOAD=true

# Enable/disable detailed error messages
ENABLE_DETAILED_ERRORS=true

# Mock API responses for testing (true/false)
MOCK_API_RESPONSES=false

# ===========================================
# INSTRUCTIONS
# ===========================================

# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your API keys (at minimum NEWS_API_KEY and ANTHROPIC_API_KEY)
# 3. Adjust other settings as needed
# 4. Never commit your .env file to version control
# 5. Keep your API keys secure and rotate them regularly

# ===========================================
# GETTING API KEYS
# ===========================================

# News API:
# 1. Go to https://newsapi.org/
# 2. Sign up for a free account
# 3. Copy your API key from the dashboard
# 4. Free tier includes 1000 requests/month

# Anthropic Claude:
# 1. Go to https://console.anthropic.com/
# 2. Create an account and verify your email
# 3. Add credits to your account
# 4. Go to API Keys section and generate a new key
# 5. Copy the key (it starts with 'sk-ant-')

# Social Pilot (Optional):
# 1. Go to https://app.socialpilot.co/
# 2. Sign up for an account
# 3. Go to Settings > API Access
# 4. Generate your API key
# 5. Copy the key for social media posting features